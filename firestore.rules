rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Assignments — anyone signed in can read, only teacher can write
    match /assignments/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.email == 'amcrae@rvschools.ab.ca';
    }

    // Rubrics — only teacher can read/write
    match /rubrics/{id} {
      allow read, write: if request.auth.token.email == 'amcrae@rvschools.ab.ca';
    }

    // Submissions — student can create/update their own, teacher can read/update all
    match /submissions/{id} {
      allow read: if request.auth != null
        && (request.auth.token.email == 'amcrae@rvschools.ab.ca'
            || resource.data.studentEmail == request.auth.token.email);
      allow write: if request.auth.token.email == 'amcrae@rvschools.ab.ca'
        || (request.auth != null
            && request.resource.data.studentEmail == request.auth.token.email);
    }

    // Accesses — students write their own, teacher reads all
    match /accesses/{id} {
      allow read: if request.auth.token.email == 'amcrae@rvschools.ab.ca';
      allow write: if request.auth != null;
    }

    // Help requests — students create, teacher reads/resolves
    match /help_requests/{id} {
      allow create: if request.auth != null;
      allow read, update: if request.auth.token.email == 'amcrae@rvschools.ab.ca';
    }

    // Sections — any authenticated user can read (students pick their class)
    // Only teacher can write
    match /sections/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.email == 'amcrae@rvschools.ab.ca';
    }

    // Enrollments — one per student per section (deterministic ID)
    // Teacher reads all; students read/create/delete their own
    match /enrollments/{id} {
      allow read: if request.auth.token.email == 'amcrae@rvschools.ab.ca'
        || resource.data.studentEmail == request.auth.token.email;
      allow create, update: if request.auth != null
        && request.resource.data.studentEmail == request.auth.token.email;
      allow delete: if request.auth.token.email == 'amcrae@rvschools.ab.ca'
        || resource.data.studentEmail == request.auth.token.email;
    }

    // Archived submission years (submissions_YYYY_YYYY) — teacher only
    match /{archiveCollection}/{id} {
      allow read, write: if request.auth.token.email == 'amcrae@rvschools.ab.ca'
        && archiveCollection.matches('submissions_[0-9]{4}_[0-9]{4}');
    }
  }
}
