rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Activity prompt images — anyone can read, only room participants write
    // Path: rooms/{roomCode}/prompt.{ext}
    match /rooms/{roomCode}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
